VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key-here

# Google Calendar API
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your-google-api-key-here

# SignWell E-Sign (server-side only — set via Supabase secrets, NOT here)
# supabase secrets set SIGNWELL_API_KEY=your_key_here
# supabase secrets set SIGNWELL_WEBHOOK_SECRET=your_webhook_secret_here
